<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PlaneScheduler — Dashboard</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <!-- Navbar -->
  <nav class="navbar navbar-expand-md navbar-dark bg-dark">
    <div class="container-fluid">
      <a class="navbar-brand" href="/"><i class="bi bi-airplane"></i> Plane Scheduler</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarContent">
        <ul class="navbar-nav ms-auto align-items-center">
          <% if (user.privileges === 'admin' || user.privileges === 'maintainer') { %>
          <li class="nav-item me-3">
            <a class="nav-link" href="/admin"><i class="bi bi-shield-lock"></i> Admin</a>
          </li>
          <% } %>
          <li class="nav-item me-3">
            <a class="nav-link" href="/settings"><i class="bi bi-person-circle"></i> <%= user.username %></a>
          </li>
          <li class="nav-item">
            <form action="/auth/logout" method="POST" class="d-inline">
              <button class="btn btn-outline-light btn-sm" type="submit">Logout</button>
            </form>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container-fluid mt-3 mb-5" data-user-id="<%= user.id %>" data-user-privileges="<%= user.privileges %>" data-user-username="<%= user.username %>">
    <%- include('partials/flash') %>

    <!-- Aircraft selector -->
    <div class="row mb-3">
      <div class="col-md-4" id="aircraftSelectGroup">
        <label for="aircraftSelect" class="form-label fw-bold">Select Aircraft</label>
        <select id="aircraftSelect" class="form-select">
          <option value="">All Aircraft</option>
        </select>
      </div>
      <div class="col-md-8 d-flex align-items-end flex-wrap gap-2 mt-2 mt-md-0">
        <button class="btn btn-sm btn-primary" id="newReservationBtn">
          <i class="bi bi-plus-lg"></i> <span class="d-none d-md-inline">New </span>Reservation
        </button>
        <button class="btn btn-sm btn-warning" data-bs-toggle="modal" data-bs-target="#issueModal">
          <i class="bi bi-exclamation-triangle"></i> <span class="d-none d-md-inline">Report </span>Issue
        </button>

      </div>
    </div>

    <!-- Grounded aircraft banner -->
    <div id="groundedBanner" class="grounded-banner d-none mb-3">
      <div class="d-flex align-items-center flex-wrap gap-2">
        <span class="grounded-label"><i class="bi bi-exclamation-octagon-fill"></i> GROUNDED</span>
        <span id="groundedList"></span>
      </div>
    </div>

    <div class="row">
      <!-- Calendar column -->
      <div class="col-lg-8 mb-4">
        <div class="card shadow-sm">
          <div class="card-body">
            <div id="calendar"></div>
          </div>
        </div>
      </div>

      <!-- Issues panel -->
      <div class="col-lg-4 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-warning-subtle d-flex justify-content-between align-items-center">
            <strong><i class="bi bi-exclamation-triangle"></i> Aircraft Issues</strong>
            <span id="issueCount" class="badge bg-warning text-dark">0</span>
          </div>
          <div class="card-body p-0">
            <div id="issueList" class="list-group list-group-flush" style="max-height:500px;overflow-y:auto;">
              <div class="list-group-item text-muted text-center py-4">No issues reported</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Reservation Modal (Create / Edit) -->
  <div class="modal fade" id="reservationModal" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="resModalTitle"><i class="bi bi-calendar-plus"></i> New Reservation</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <form id="reservationForm">
            <input type="hidden" id="resId" value="" />
            <div class="mb-3">
              <label for="resAircraft" class="form-label">Aircraft</label>
              <select id="resAircraft" class="form-select" required></select>
            </div>
            <div class="mb-3">
              <label for="resUser" class="form-label">User</label>
              <select id="resUser" class="form-select" required></select>
            </div>
            <div class="mb-3">
              <label for="resTitle" class="form-label">Type</label>
              <select id="resTitle" class="form-select" required>
                <option value="Personal" selected>Personal</option>
                <option value="Shared">Shared</option>
                <option value="Maintenance">Maintenance</option>
              </select>
            </div>
            <div class="row">
              <div class="col-md-6 mb-3">
                <label for="resStart" class="form-label">Start</label>
                <input type="datetime-local" class="form-control" id="resStart" required />
              </div>
              <div class="col-md-6 mb-3">
                <label for="resEnd" class="form-label">End</label>
                <input type="datetime-local" class="form-control" id="resEnd" required />
              </div>
            </div>
            <div class="mb-3">
              <label for="resNotes" class="form-label">Notes (optional)</label>
              <textarea class="form-control" id="resNotes" rows="2"></textarea>
            </div>
            <div class="row d-none" id="resHobbsGroup">
              <div class="col-md-6 mb-3">
                <label for="resStartHobbs" class="form-label">Hobbs Start</label>
                <input type="number" class="form-control" id="resStartHobbs" min="0" step="0.1" />
              </div>
              <div class="col-md-6 mb-3">
                <label for="resEndHobbs" class="form-label">Hobbs End</label>
                <input type="number" class="form-control" id="resEndHobbs" min="0" step="0.1" />
              </div>
            </div>
            <div id="resError" class="alert alert-danger d-none"></div>
          </form>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="button" class="btn btn-primary" id="submitReservation">
            <span class="spinner-border spinner-border-sm d-none" id="resSpinner"></span>
            <span id="resBtnLabel">Create Reservation</span>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Report Issue Modal -->
  <div class="modal fade" id="issueModal" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title"><i class="bi bi-exclamation-triangle"></i> Report Issue</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <form id="issueForm">
            <div class="mb-3">
              <label for="issAircraft" class="form-label">Aircraft</label>
              <select id="issAircraft" class="form-select" required></select>
            </div>
            <div class="mb-3">
              <label for="issTitle" class="form-label">Issue Title</label>
              <input type="text" class="form-control" id="issTitle" required />
            </div>
            <div class="mb-3">
              <label for="issSeverity" class="form-label">Severity</label>
              <select id="issSeverity" class="form-select" required>
                <option value="low">Low</option>
                <option value="medium" selected>Medium</option>
                <option value="high">High</option>
                <option value="grounding">Grounding</option>
              </select>
            </div>
            <div class="mb-3">
              <label for="issDescription" class="form-label">Description (optional)</label>
              <textarea class="form-control" id="issDescription" rows="3"></textarea>
            </div>
            <div id="issError" class="alert alert-danger d-none"></div>
          </form>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="button" class="btn btn-warning" id="submitIssue">
            <span class="spinner-border spinner-border-sm d-none" id="issSpinner"></span>
            Submit Issue
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Reservation Detail Modal -->
  <div class="modal fade" id="reservationDetailModal" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="detailTitle">Reservation Details</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body" id="detailBody"></div>
        <div class="modal-footer">
          <button type="button" class="btn btn-primary d-none" id="editReservation">
            <i class="bi bi-pencil"></i> Edit
          </button>
          <button type="button" class="btn btn-danger d-none" id="deleteReservation">
            <i class="bi bi-trash"></i> Delete
          </button>
          <button type="button" class="btn btn-success d-none" id="completeReservation">
            <i class="bi bi-check-circle"></i> Complete
          </button>
          <button type="button" class="btn btn-outline-warning d-none" id="uncompleteReservation">
            <i class="bi bi-arrow-counterclockwise"></i> Uncomplete
          </button>
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
        </div>
      </div>
    </div>
  </div>



  <!-- Complete Reservation Modal -->
  <div class="modal fade" id="completeModal" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title"><i class="bi bi-check-circle"></i> Complete Reservation</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <form id="completeForm">
            <div class="mb-3">
              <label for="compStartHobbs" class="form-label">Hobbs Start</label>
              <input type="number" class="form-control" id="compStartHobbs" min="0" step="0.1" required />
            </div>
            <div class="mb-3">
              <label for="compEndHobbs" class="form-label">Hobbs End</label>
              <input type="number" class="form-control" id="compEndHobbs" min="0" step="0.1" required />
            </div>
            <div id="compError" class="alert alert-danger d-none"></div>
          </form>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="button" class="btn btn-success" id="submitComplete">
            <span class="spinner-border spinner-border-sm d-none" id="compSpinner"></span>
            Mark Complete
          </button>
        </div>
      </div>
    </div>
  </div>



  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@fullcalendar/bootstrap5@6.1.15/index.global.min.js"></script>
  <script src="/js/app.js"></script>
</body>
</html>
