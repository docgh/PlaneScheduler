<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PlaneScheduler — Admin</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <!-- Navbar -->
  <nav class="navbar navbar-expand-md navbar-dark bg-dark">
    <div class="container-fluid">
      <a class="navbar-brand" href="/"><i class="bi bi-airplane"></i> Plane Scheduler</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarContent">
        <ul class="navbar-nav ms-auto align-items-center">
          <li class="nav-item me-3">
            <a class="nav-link" href="/settings"><i class="bi bi-person-circle"></i> <%= user.username %></a>
          </li>
          <li class="nav-item">
            <form action="/auth/logout" method="POST" class="d-inline">
              <button class="btn btn-outline-light btn-sm" type="submit">Logout</button>
            </form>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container mt-4 mb-5" data-user-id="<%= user.id %>" data-user-privileges="<%= user.privileges %>">
    <%- include('partials/flash') %>

    <div class="d-flex align-items-center mb-4">
      <a href="/" class="btn btn-outline-secondary btn-sm me-3"><i class="bi bi-arrow-left"></i> Dashboard</a>
      <h4 class="mb-0"><i class="bi bi-shield-lock"></i> Administration</h4>
    </div>

    <% if (user.privileges === 'admin') { %>
    <!-- User Management -->
    <div class="card shadow-sm mb-4">
      <div class="card-header bg-light d-flex justify-content-between align-items-center">
        <strong><i class="bi bi-people"></i> User Management</strong>
        <button class="btn btn-sm btn-primary" id="addUserBtn"><i class="bi bi-plus-lg"></i> Add User</button>
      </div>
      <div class="card-body">
        <!-- Pending users section -->
        <h6 class="mb-3"><i class="bi bi-hourglass-split"></i> Pending Approval <span id="pendingCount" class="badge bg-danger">0</span></h6>
        <div id="pendingUsersList" class="mb-4">
          <p class="text-muted">No pending users</p>
        </div>
        <hr />
        <!-- All users section -->
        <h6 class="mb-3"><i class="bi bi-person-lines-fill"></i> All Users</h6>
        <div class="table-responsive">
          <table class="table table-sm table-hover" id="allUsersTable">
            <thead>
              <tr>
                <th>Username</th>
                <th>Email</th>
                <th>Privileges</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="allUsersBody">
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Aircraft Management -->
    <div class="card shadow-sm mb-4">
      <div class="card-header bg-light d-flex justify-content-between align-items-center">
        <strong><i class="bi bi-airplane-engines"></i> Fleet Management</strong>
        <button class="btn btn-sm btn-primary" id="addAircraftBtn"><i class="bi bi-plus-lg"></i> Add Aircraft</button>
      </div>
      <div class="card-body">
        <div class="table-responsive">
          <table class="table table-sm table-hover">
            <thead>
              <tr>
                <th>Tail #</th>
                <th>Make</th>
                <th>Model</th>
                <th>Year</th>
                <th>Hobbs</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="aircraftMgmtBody">
            </tbody>
          </table>
        </div>
      </div>
    </div>
    <% } %>

    <!-- Usage Report -->
    <div class="card shadow-sm mb-4">
      <div class="card-header bg-light">
        <strong><i class="bi bi-file-earmark-spreadsheet"></i> Usage Report</strong>
      </div>
      <div class="card-body">
        <form id="usageReportForm">
          <div class="row align-items-end">
            <div class="col-md-3 mb-3">
              <label for="usageAircraft" class="form-label">Aircraft</label>
              <select id="usageAircraft" class="form-select">
                <option value="">All Aircraft</option>
              </select>
            </div>
            <div class="col-md-3 mb-3">
              <label for="usageStart" class="form-label">Start Date</label>
              <input type="date" class="form-control" id="usageStart" required />
            </div>
            <div class="col-md-3 mb-3">
              <label for="usageEnd" class="form-label">End Date</label>
              <input type="date" class="form-control" id="usageEnd" required />
            </div>
            <div class="col-md-3 mb-3">
              <button type="button" class="btn btn-primary w-100" id="exportUsage">
                <i class="bi bi-download"></i> Export CSV
              </button>
            </div>
          </div>
          <div id="usageError" class="alert alert-danger d-none"></div>
        </form>
      </div>
    </div>
  </div>

  <!-- Add/Edit User Modal -->
  <% if (user.privileges === 'admin') { %>
  <div class="modal fade" id="userFormModal" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="userFormTitle"><i class="bi bi-person-plus"></i> Add User</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <form id="userForm">
            <input type="hidden" id="ufId" />
            <div class="mb-3">
              <label for="ufUsername" class="form-label">Username</label>
              <input type="text" class="form-control" id="ufUsername" minlength="3" maxlength="50" required />
            </div>
            <div class="mb-3">
              <label for="ufEmail" class="form-label">Email</label>
              <input type="email" class="form-control" id="ufEmail" required />
            </div>
            <div class="mb-3">
              <label for="ufPassword" class="form-label">Password <span id="ufPasswordHint" class="text-muted small"></span></label>
              <input type="password" class="form-control" id="ufPassword" minlength="6" />
            </div>
            <div class="mb-3">
              <label for="ufPrivileges" class="form-label">Privileges</label>
              <select id="ufPrivileges" class="form-select" required>
                <option value="user">user</option>
                <option value="maintainer">maintainer</option>
                <option value="admin">admin</option>
                <option value="pending">pending</option>
              </select>
            </div>
            <div id="ufError" class="alert alert-danger d-none"></div>
          </form>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="button" class="btn btn-primary" id="submitUserForm">
            <span class="spinner-border spinner-border-sm d-none" id="ufSpinner"></span>
            Save User
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Add/Edit Aircraft Modal -->
  <div class="modal fade" id="aircraftFormModal" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="acFormTitle"><i class="bi bi-airplane"></i> Add Aircraft</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <form id="aircraftForm">
            <input type="hidden" id="acfId" />
            <div class="mb-3">
              <label for="acfTail" class="form-label">Tail Number</label>
              <input type="text" class="form-control" id="acfTail" required />
            </div>
            <div class="mb-3">
              <label for="acfMake" class="form-label">Make</label>
              <input type="text" class="form-control" id="acfMake" required />
            </div>
            <div class="mb-3">
              <label for="acfModel" class="form-label">Model</label>
              <input type="text" class="form-control" id="acfModel" required />
            </div>
            <div class="row">
              <div class="col-md-6 mb-3">
                <label for="acfYear" class="form-label">Year</label>
                <input type="number" class="form-control" id="acfYear" min="1900" max="2100" />
              </div>
              <div class="col-md-6 mb-3">
                <label for="acfHobbs" class="form-label">Last Hobbs</label>
                <input type="number" class="form-control" id="acfHobbs" min="0" step="0.1" value="0" />
              </div>
            </div>
            <div id="acfError" class="alert alert-danger d-none"></div>
          </form>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="button" class="btn btn-primary" id="submitAircraftForm">
            <span class="spinner-border spinner-border-sm d-none" id="acfSpinner"></span>
            Save Aircraft
          </button>
        </div>
      </div>
    </div>
  </div>
  <% } %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/admin.js"></script>
</body>
</html>
